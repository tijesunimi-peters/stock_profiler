# Required by the SEC for all automated requests. Identify your app + a contact email.
# Requests without a descriptive User-Agent are blocked by the SEC.
SEC_USER_AGENT="sec-financials-api you@example.com"

# Local cache / DB location (SQLite for dev). Swap for a Postgres URL later.
SECFIN_DB_PATH="./data/secfin.db"

# Max SEC requests per second. Do not raise above the SEC fair-access limit.
SEC_MAX_RPS=8

# Per-IP burst limit (req/s) for the keyless public endpoints (statements, periods) that
# back the public Data Explorer (/explorer). Everything else requires an API key --
# POST /v1/signup issues one (see auth/tiers.py for the default "free" tier's own limits).
SECFIN_ANON_RATE_LIMIT_PER_SEC=2.0

# Shared secret for admin-only endpoints (moving an API key onto a paid tier -- there's
# no self-service upgrade/payment flow yet). Sent as the X-Admin-Secret header. Leave
# unset in dev; the admin endpoints 503 until this is set. Set a long random value
# before deploying anywhere reachable.
SECFIN_ADMIN_SECRET=

# Bulk backfill tuning (ingest/backfill.py, `python -m secfin.ingest.backfill`). All
# optional -- these are the same defaults build_arg_parser() falls back to; set here (or
# pass the equivalent --data-dir/--workers/--batch-size/--queue-maxsize CLI flags) only
# if you want to override them. 0 workers => auto-detect max(1, cpu_count() - 1).
SECFIN_BULK_DATA_DIR="./data/bulk"
SECFIN_BACKFILL_WORKERS=0
SECFIN_BACKFILL_BATCH_SIZE=5000
SECFIN_BACKFILL_QUEUE_MAXSIZE=50
