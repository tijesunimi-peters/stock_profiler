# Required by the SEC for all automated requests. Identify your app + a contact email.
# Requests without a descriptive User-Agent are blocked by the SEC.
SEC_USER_AGENT="sec-financials-api you@example.com"

# Local cache / DB location (SQLite for dev). Swap for a Postgres URL later.
SECFIN_DB_PATH="./data/secfin.db"

# Max SEC requests per second. Do not raise above the SEC fair-access limit.
SEC_MAX_RPS=8

# Per-IP burst limit (req/s) for the keyless public endpoints (statements, periods) that
# back the public Data Explorer (/explorer). Everything else requires an API key --
# POST /v1/signup issues one (see auth/tiers.py for the default "free" tier's own limits).
SECFIN_ANON_RATE_LIMIT_PER_SEC=2.0
